{
  "name": "instant-cleanup",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "predev": "node ./scripts/sync-ort-assets.mjs",
    "prebuild": "node ./scripts/sync-ort-assets.mjs",
    "cf:deploy": "npm run build && wrangler pages deploy",
    "cf:dev": "npm run build && wrangler pages dev",
    "cf:project:create": "wrangler pages project create instant-cleanup",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "check": "npm run lint && npm run build",
    "lint": "eslint .",
    "model:fetch": "bash ./scripts/fetch-model.sh",
    "preview": "vite preview"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/space-grotesk": "^5.2.10",
    "konva": "^10.3.0",
    "onnxruntime-web": "^1.26.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-konva": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
